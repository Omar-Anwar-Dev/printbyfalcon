# Database
DATABASE_URL=postgresql://user:password@postgres-db:5432/printbyfalcon

# Redis
REDIS_URL=redis://redis-cache:6379
REDIS_PASSWORD=your_redis_password

# Meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your_meilisearch_master_key

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=printbyfalcon-media
# MinIO public URL (set in production to your domain or IP)
MINIO_PUBLIC_URL=https://api.printbyfalcon.com/media

# JWT
JWT_SECRET=your_jwt_secret_256bit
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_256bit
JWT_REFRESH_EXPIRES_IN=7d

# Paymob
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID_CARD=your_card_integration_id
PAYMOB_INTEGRATION_ID_FAWRY=your_fawry_integration_id
PAYMOB_HMAC_SECRET=your_hmac_secret

# Email / SMS
SMTP_HOST=smtp.sendgrid.net
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_key
VONAGE_API_KEY=your_vonage_key
VONAGE_API_SECRET=your_vonage_secret

# App
NEXT_PUBLIC_API_URL=https://api.printbyfalcon.com
ADMIN_IP_WHITELIST=your_ip_here
SENTRY_DSN=your_sentry_dsn
SESSION_SECRET=your-session-secret-here
